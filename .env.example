# TKD Services — environment variables
# Copy relevant values into Replit Secrets (do not commit a real .env file).
# See README.md "Environment variables / secrets" for what each one is used
# by. artifacts/booking-service/.env.example documents the booking
# microservice's own variables (BOOKING_DATABASE_URL, SMTP_*, etc.) in more
# detail — this file covers the main app plus the shared booking vars the
# main app itself needs.

# --- Main app backend (artifacts/api-server) ---
# Postgres connection string. Provisioned automatically by Replit's built-in
# database; set automatically in this environment, shown here for reference
# when running this project outside Replit.
DATABASE_URL=postgres://user:password@host:5432/tkd_services

# Secret used to sign session cookies (express-session). Generate a long
# random string; never reuse across environments.
SESSION_SECRET=replace-with-a-long-random-string

# Standard Node environment flag. "production" enables secure (HTTPS-only)
# session cookies.
NODE_ENV=development

# Port each service binds to. Replit assigns this automatically per
# artifact; only needed if running outside Replit.
PORT=8080

# --- Object Storage (résumé PDFs, portfolio images) ---
# Provisioned automatically by Replit's Object Storage tool. Outside Replit
# you need a real GCS bucket + service-account credentials — see the
# "Known gap" note in README.md.
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# --- Booking microservice integration (consumed by api-server) ---
# Where the standalone booking-service is reachable.
BOOKING_SERVICE_URL=http://localhost:8000
# Shared secret sent as `x-internal-api-key` on every call to booking-service.
BOOKING_SERVICE_API_KEY=replace-with-a-long-random-string

# --- Main app frontend (artifacts/tkd-services) ---
# Base path the frontend is served under. "/" when self-hosted; Replit sets
# this automatically per artifact.
BASE_PATH=/
