# Feature Graph — environment variables
# Copy relevant values into Replit Secrets (do not commit a real .env file).

# --- API server (artifacts/api-server) ---
# Postgres connection string. Provisioned automatically by Replit's built-in
# database; set automatically in this environment, shown here for reference
# when running this project outside Replit.
DATABASE_URL=postgres://user:password@host:5432/feature_graph

# Secret used to sign session cookies (express-session). Generate a long
# random string; never reuse across environments.
SESSION_SECRET=replace-with-a-long-random-string

# Standard Node environment flag. "production" enables secure (HTTPS-only)
# session cookies.
NODE_ENV=development

# Port the API server binds to. Replit assigns this automatically per
# artifact; only needed if running the server outside Replit.
PORT=8080

# --- CLI (cli/) ---
# Base URL the CLI talks to, including the /api prefix. Defaults to
# http://localhost:8080/api when unset and REPLIT_DEV_DOMAIN is not present.
FEATURE_GRAPH_API_URL=http://localhost:8080/api

# Set to 1 to show DEBUG/VERBOSE log lines from the CLI.
FEATURE_GRAPH_VERBOSE=0
