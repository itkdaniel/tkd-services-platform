# --- Database (own schema, can point at any Postgres instance) ---
BOOKING_DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Networking ---
PORT=8000
# Shared secret the caller must send as `x-internal-api-key`.
BOOKING_SERVICE_API_KEY=change-me

# --- Business hours / slots (fixed UTC offset, in minutes) ---
BUSINESS_UTC_OFFSET_MINUTES=0
BUSINESS_DAYS=1,2,3,4,5
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=17
SLOT_DURATION_MINUTES=30
MAX_BOOKING_HORIZON_DAYS=60

# --- Notification recipient (the "admin"/receiving party) ---
ADMIN_NOTIFICATION_EMAIL=admin@example.com
ADMIN_NOTIFICATION_LABEL=Admin

# --- Email provider: "gmail" (default, via Replit Gmail connector) or "smtp" ---
EMAIL_PROVIDER=gmail
EMAIL_FROM=bookings@example.com

# --- SMTP provider config (only used when EMAIL_PROVIDER=smtp) ---
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Reminder scheduler cadence ---
REMINDER_CHECK_CRON=*/15 * * * *
